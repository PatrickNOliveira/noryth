# ── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=3333

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=noryth
DATABASE_PASSWORD=noryth
DATABASE_NAME=noryth
# NOTE: TypeORM `synchronize` is permanently OFF. The schema is managed
# EXCLUSIVELY by migrations, which run automatically on application boot.

# ── Auth (JWT) ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:3000

# ── Storage (MinIO) ───────────────────────────────────────────
STORAGE_DRIVER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=noryth
MINIO_USE_SSL=false
# Public base URL for stored objects. Leave empty to derive from endpoint/port.
# With the bundled docker-compose, use: http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000

# ── AI image generation (OpenAI) ──────────────────────────────
# Leave OPENAI_API_KEY empty to disable generation (factions save without a symbol).
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
# Chat model used to turn faction lore into a visual image prompt.
OPENAI_TEXT_MODEL=gpt-4o-mini

# ── Queue (Redis / BullMQ) ────────────────────────────────────
# BullMQ needs Redis. Leave REDIS_HOST empty to disable async jobs.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
