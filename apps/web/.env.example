# Base URL of the Noryth API. Note the CRA convention: browser-exposed
# variables MUST be prefixed with REACT_APP_.
REACT_APP_API_URL=http://localhost:3333/api

# Optional. Endpoint returning JSON with a country code (country_code /
# countryCode / country) used ONLY as an IP fallback for initial language
# detection (e.g. https://ipapi.co/json/). Leave empty to use browser + default.
REACT_APP_GEO_API_URL=
