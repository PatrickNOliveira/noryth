# ─────────────────────────────────────────────────────────────
# Noryth — production environment templates
#
# These values are NOT committed with real content. On the VPS they live as:
#   /opt/noryth/api.env   (from the API section below)
#   /opt/noryth/web.env   (from the WEB section below)
#
# In GitHub, store the full contents of each section as secrets:
#   API_ENV_FILE  → api.env
#   WEB_ENV_FILE  → web.env
# The deploy workflow writes them to the VPS and passes them via --env-file.
# Postgres and MinIO are EXTERNAL — this project never creates them.
# ─────────────────────────────────────────────────────────────

# ===== API (/opt/noryth/api.env) =============================
NODE_ENV=production
PORT=3000

DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=

JWT_SECRET=
JWT_EXPIRES_IN=7d

STORAGE_DRIVER=minio

# INTERNAL endpoint — how the API reaches MinIO to read/write objects (S3 API).
# This stays on the private network/host and is NOT what the browser sees. From
# inside the API container use the host's reachable address (e.g. the Docker
# bridge gateway 172.17.0.1) — not 127.0.0.1, which would be the container itself.
MINIO_ENDPOINT=172.17.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=noryth-assets
MINIO_USE_SSL=false

# PUBLIC base URL returned to the browser for stored objects. Must be HTTPS to
# avoid mixed content. The bucket name is appended automatically, so the final
# URL is:  ${MINIO_PUBLIC_URL}/${MINIO_BUCKET}/<path>
#   -> https://assets.noryth.io/noryth-assets/campaigns/<id>/cover/cover.png
# Do NOT include the bucket here.
MINIO_PUBLIC_URL=https://assets.noryth.io

# Origins allowed by CORS — comma-separated. Include apex and www.
WEB_ORIGIN=https://noryth.io,https://www.noryth.io

# AI image generation (faction symbols). Empty = feature disabled.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_TEXT_MODEL=gpt-4o-mini

# Queue (Redis / BullMQ) — required for async image generation.
# Point to your EXTERNAL Redis (not created by this project). Empty = jobs off.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== WEB (/opt/noryth/web.env) =============================
# Injected into the browser at container start (window._env_), NOT baked at build.
REACT_APP_API_URL=https://api.noryth.io/api
